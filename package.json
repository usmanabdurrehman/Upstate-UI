  },
  "scripts": {
    "server": "nodemon server.js",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build-lib": "rollup -c rollup.config.js",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "storybook": "start-storybook -p 6006 -s public",
